{
  "name": "video-producer",
  "version": "0.1.0",
  "description": "AI-orchestrated product showcase video generator — 30s 9:16 / 16:9 shorts via Runway + ElevenLabs + Remotion.",
  "author": {
    "name": "Johnny Lin"
  },
  "license": "AGPL-3.0",
  "keywords": ["video", "product-video", "shorts", "runway", "elevenlabs", "remotion"],

  "mcpServers": {
    "video-producer": {
      "command": "python",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/server.py"],
      "env": {
        "VIDEO_PRODUCER_PLUGIN_ROOT": "${CLAUDE_PLUGIN_ROOT}"
      }
    }
  }
}
