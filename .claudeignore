# ===================================================================
#  Claude Code plugin packaging — explicit exclusions
#
#  This file is read by `/plugin add` when packaging the folder. Keep it
#  aligned with .gitignore but stricter — we MUST stay under the 100 MB
#  plugin size limit.
# ===================================================================

# --- Bulk: npm / node / python runtime artifacts (regenerated by install.sh) ---
**/node_modules/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.egg-info/
.venv/
venv/
dist/
build/

# --- Plugin output workspace (generated MP4s, intermediate renders) ---
projects/

# --- Remotion staged assets (generated per render; regenerable) ---
remotion-composer/public/
# Allow demo-props reference (tiny, useful for first-boot sanity checks)
!remotion-composer/public/demo-props/

# --- Version control metadata (not needed at runtime) ---
.git/
.gitignore   # keep .claudeignore as the source of truth
.github/

# --- Local tmp / caches ---
.DS_Store
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
htmlcov/
.coverage
.trae/
.idea/
.vscode/

# --- Secrets: never package the filled-in .env ---
.env
.env.local
.env.*.local

# --- Local-only pipeline outputs (don't ship with plugin) ---
output/
pipeline/
tests/qa/output/
corpora/
corpus_*/

# --- Miscellaneous large asset dumps that may appear during dev ---
*.mov
*.avi
# But KEEP small reference files intentionally committed under assets/
!assets/**/*.mov
!assets/**/*.avi

# MP4 general: exclude at root, keep selected reference files if any
*.mp4
!assets/**/*.mp4           # keep any shipped demo MP4 under assets/
!remotion-composer/public/demo-props/**/*.mp4
